# for any lingering local data from pre-refactor runs.
benchmarks/results/
benchmark_results/
benchmark_checkpoints/

# Benchmark credentials — API keys + base URLs; covered by the top-level
# .env pattern but listed explicitly for discoverability.
benchmarks/.env

